{"cells":[{"cell_type":"code","source":"import json\nimport urllib.request\nimport sys\n\ndef fetch_jdm_data():\n    \"\"\"\n    Fetches the raw sites.json from the official JustDeleteMe GitHub repository.\n    \"\"\"\n    url = \"https://raw.githubusercontent.com/justdeleteme/justdelete.me/master/sites.json\"\n    try:\n        with urllib.request.urlopen(url) as response:\n            if response.status == 200:\n                return json.loads(response.read().decode())\n            else:\n                print(f\"Error: Received status code {response.status}\")\n                return None\n    except Exception as e:\n        print(f\"Failed to fetch data: {e}\")\n        return None\n\ndef filter_by_difficulty(data, levels):\n    \"\"\"\n    Filters the dataset based on a list of difficulty levels.\n    \"\"\"\n    if not isinstance(levels, list):\n        levels = [levels]\n    \n    return [site for site in data if site.get('difficulty') in levels]\n\ndef main():\n    print(\"Fetching latest JustDeleteMe directory...\")\n    data = fetch_jdm_data()\n    \n    if not data:\n        sys.exit(1)\n\n    print(f\"Successfully loaded {len(data)} services.\\n\")\n\n    # Define groups for processing\n    categories = {\n        \"Critical (Impossible)\": [\"impossible\"],\n        \"Manual/High Effort (Hard)\": [\"hard\"],\n        \"Standard (Easy/Medium)\": [\"easy\", \"medium\"]\n    }\n\n    for label, levels in categories.items():\n        filtered = filter_by_difficulty(data, levels)\n        print(f\"--- {label} ({len(filtered)} items) ---\")\n        \n        # Displaying first 10 for brevity in console output\n        for site in filtered[:10]:\n            name = site.get('name', 'Unknown')\n            difficulty = site.get('difficulty', 'N/A')\n            url = site.get('url', 'No URL')\n            notes = site.get('notes', 'No specific instructions.')\n            \n            print(f\"[{name}] ({difficulty})\")\n            print(f\"  Target: {url}\")\n            print(f\"  Guidance: {notes[:100]}...\" if len(notes) > 100 else f\"  Guidance: {notes}\")\n            print(\"-\" * 30)\n        \n        if len(filtered) > 10:\n            print(f\"... and {len(filtered) - 10} more.\\n\")\n\nif __name__ == \"__main__\":\n    main()","outputs":[],"execution_count":null,"metadata":{}}],"metadata":{"colab":{"from_bard":true},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}