    os.path.join(src_main, "ExampleService.java"): """package net.runelite.client.plugins.example;

import lombok.extern.slf4j.Slf4j;
import net.runelite.api.Client;
import net.runelite.api.events.GameStateChanged;

import javax.inject.Inject;
import javax.inject.Singleton;

@Slf4j
@Singleton
public class ExampleService
{
    private final Client client;
    private final ExampleConfig config;

    @Inject
    public ExampleService(Client client, ExampleConfig config)
    {
        this.client = client;
        this.config = config;
    }

    public boolean performAction()
    {
        if (!config.enablePlugin())
        {
            log.debug("Plugin disabled – action aborted");
            return false;
        }
        log.info("Performing core service action");
        return true;
    }

    public void handleGameState(GameStateChanged ev)
    {
        if (ev.getGameState() == net.runelite.api.GameState.LOGGED_IN && client.getLocalPlayer() != null)
        {
            log.info("Player logged in as {}", client.getLocalPlayer().getName());
        }
    }
}
