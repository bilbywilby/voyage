import lombok.extern.slf4j.Slf4j;
import net.runelite.api.Client;
import javax.inject.Inject;
import javax.inject.Singleton;
import java.awt.*;

@Slf4j
@Singleton
public class UXService
{
    private final ExampleConfig config;
    private final Client client;

    @Inject
    public UXService(ExampleConfig config, Client client)
    {
        this.config = config;
        this.client = client;
    }

    public void onStart()
    {
        if (config.accessibilityMode())
        {
            log.info("Accessibility mode enabled: High contrast overlays & larger text.");
        }
        notifyUser("Plugin Started", "Example Plugin is now active.");
    }

    public void onStop()
    {
        notifyUser("Plugin Stopped", "Example Plugin has been disabled.");
    }

    public void onTick() { }

    private void notifyUser(String title, String message)
    {
        if (!config.showNotifications()) return;
        log.info("[NOTIFICATION] {} - {}", title, message);
    }
}
"""
