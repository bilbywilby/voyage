import com.google.inject.Provides;
import lombok.extern.slf4j.Slf4j;
import net.runelite.api.events.GameTick;
import net.runelite.api.events.GameStateChanged;
import net.runelite.client.config.ConfigManager;
import net.runelite.client.eventbus.Subscribe;
import net.runelite.client.plugins.Plugin;
import net.runelite.client.plugins.PluginDescriptor;
import net.runelite.client.ui.overlay.OverlayManager;

import javax.inject.Inject;

@Slf4j
@PluginDescriptor(
    name = "Example Plugin",
    description = "A production-grade RuneLite plugin with UX integration",
    tags = {"example", "ux", "template"},
    enabledByDefault = false
)
public class ExamplePlugin extends Plugin
{
    @Inject private ExampleConfig config;
    @Inject private ExampleService service;
    @Inject private UXService uxService;
    @Inject private ExampleOverlay overlay;
    @Inject private OverlayManager overlayManager;
    @Inject private ConfigManager configManager;

    @Override
    protected void startUp() throws Exception
    {
        if (!config.enablePlugin())
        {
            log.info("Plugin disabled via config");
            return;
        }

        overlayManager.add(overlay);
        uxService.onStart();
        log.info("Example plugin started");
    }

    @Override
    protected void shutDown() throws Exception
    {
        overlayManager.remove(overlay);
        uxService.onStop();
        log.info("Example plugin stopped");
    }

    @Subscribe
    public void onGameStateChanged(GameStateChanged ev)
    {
        if (!config.enablePlugin()) return;
        service.handleGameState(ev);
    }

    @Subscribe
    public void onGameTick(GameTick ev)
    {
        if (!config.enablePlugin()) return;
        overlay.update(ev);
        uxService.onTick();
    }

    @Provides
    ExampleConfig provideConfig(ConfigManager configManager)
    {
        return configManager.getConfig(ExampleConfig.class);
    }
}
""",

